<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rt.daemon</string>

    <key>BundleProgram</key>
    <string>Contents/MacOS/rt-daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>Contents/MacOS/rt-daemon</string>
        <string>--daemon</string>
    </array>

    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.rt.tray</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- NOTE: StandardOutPath/StandardErrorPath intentionally omitted.
         macOS 26 broke $(HOME) expansion in SMAppService-registered plists,
         causing EX_CONFIG / spawn failed. The daemon binary redirects its
         own output to ~/.rt/daemon.log and ~/.rt/daemon-stderr.log directly. -->

    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
