<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rt.daemon</string>

    <key>BundleProgram</key>
    <string>Contents/MacOS/rt-daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>Contents/MacOS/rt-daemon</string>
        <string>--daemon</string>
    </array>

    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.rt.tray</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Capture all output so crashes before lib/daemon.ts starts are visible -->
    <key>StandardOutPath</key>
    <string>$(HOME)/.rt/daemon-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>$(HOME)/.rt/daemon-stderr.log</string>

    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
