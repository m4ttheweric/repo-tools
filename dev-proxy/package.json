{
  "name": "dev-proxy",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-worktree reverse proxy for local dev with Auth0-compatible cookie-based routing",
  "type": "module",
  "scripts": {
    "start": "bun run dev-proxy.ts",
    "dev": "bun --watch run dev-proxy.ts",
    "orchestrate": "bun run orchestrate.ts",
    "dump-tiltfile": "bun run dump-tiltfile.ts -o Tiltfile",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@tilt-launcher/sdk": "^1.2.2",
    "@types/react": "19",
    "eta": "^4.5.1",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "react": "19"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
