<% if (it.active) { %>
<div
  style="display:flex;align-items:center;gap:8px;padding:7px 12px;font-size:13px;white-space:nowrap">
  <span style="width:14px;text-align:center;flex-shrink:0;color:#22c55e;font-size:13px">✓</span>
  <span style="font-weight:600;color:#0f172a"><%= it.name %></span>
  <% if (it.branch) { %>
    <span style="color:#64748b;font-size:11px"><%= it.branch %></span>
  <% } %>
</div>
<% } else { %>
<a href="<%= it.path %>"
  onclick="event.preventDefault();location.href='<%= it.path %>?next='+encodeURIComponent(location.pathname+location.search)"
  style="display:flex;align-items:center;gap:8px;padding:7px 12px;
    text-decoration:none;font-size:13px;white-space:nowrap;transition:background .1s"
  onmouseenter="this.style.background='#f1f5f9'"
  onmouseleave="this.style.background='transparent'">
  <span style="width:14px;flex-shrink:0"></span>
  <span style="font-weight:600;color:#334155"><%= it.name %></span>
  <% if (it.branch) { %>
    <span style="color:#94a3b8;font-size:11px"><%= it.branch %></span>
  <% } %>
</a>
<% } %>
