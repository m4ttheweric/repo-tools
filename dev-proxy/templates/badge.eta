<!-- dev-proxy badge -->
<div id="__dp" style="position:fixed;bottom:12px;right:12px;z-index:2147483647;font-family:system-ui,sans-serif;font-size:13px">
  <div id="__dp-pill"
    style="background:<%= it.color %>;color:#fff;padding:5px 14px 5px 12px;border-radius:20px;cursor:pointer;
      box-shadow:0 2px 8px rgba(0,0,0,.25);user-select:none;display:flex;align-items:center;gap:6px;
      white-space:nowrap;opacity:0.85;transition:opacity .15s"
    onmouseenter="this.style.opacity='1'"
    onmouseleave="this.style.opacity='0.85'"
    onclick="var m=document.getElementById('__dp-menu');m.style.display=m.style.display==='none'?'block':'none'">
    <span style="width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.9);flex-shrink:0"></span>
    <%= it.name %>
    <% if (it.branch) { %>
      <span style="opacity:.7;font-size:11px;font-weight:400"><%= it.branch %></span>
    <% } %>
    <svg width="10" height="10" viewBox="0 0 10 10" style="opacity:.7;margin-left:2px">
      <path d="M2 6.5L5 3.5L8 6.5" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round"/>
    </svg>
  </div>
  <div id="__dp-menu"
    style="display:none;position:absolute;bottom:calc(100% + 6px);right:0;background:#fff;
      border-radius:8px;padding:4px 0;box-shadow:0 4px 20px rgba(0,0,0,.15);
      border:1px solid #e2e8f0">
    <%~ it.items %>
  </div>
</div>
