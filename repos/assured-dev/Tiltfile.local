# Local Development Tiltfile
# Usage: tilt up -f Tiltfile.local

print('🚀 Local Development Environment')

# ------------------------------------------------------------
# STEP 1: pnpm install
# ------------------------------------------------------------
local_resource(
    'pnpm-install',
    cmd='pnpm install',
    labels=['setup'],
)

print('📦 pnpm install will run first')

# ------------------------------------------------------------
# STEP 2: Check and fix migrations
# ------------------------------------------------------------
local_resource(
    'db-migrations',
    cmd='''
        cd apps/backend
        OUTPUT=$(pnpm run cloneDB-fix-migrations 2>&1)
        echo "$OUTPUT"
        
        # Check if migrations need to be applied (script outputs "Run: pnpm deploy-db" when needed)
        if echo "$OUTPUT" | grep -q "Run: pnpm deploy-db"; then
            echo ""
            echo "🔄 Migrations need to be applied, running deploy-db..."
            pnpm run deploy-db
        else
            echo ""
            echo "✅ Database migrations are up to date"
        fi
    ''',
    labels=['setup'],
    resource_deps=['pnpm-install'],
)

print('🗄️  Database migrations will be checked')

# ------------------------------------------------------------
# STEP 3: Generate Adjuster types
# ------------------------------------------------------------
local_resource(
    'adjuster-genTypes-init',
    cmd='cd apps/adjuster && pnpm genTypes',
    labels=['setup'],
    resource_deps=['pnpm-install'],
)

print('🔧 Adjuster types will be generated')

# ------------------------------------------------------------
# BACKEND
# ------------------------------------------------------------
local_resource(
    'backend',
    serve_cmd='cd apps/backend && pnpm start',
    labels=['apps'],
    resource_deps=['db-migrations'],
    links=['http://localhost:4000'],
)

print('✅ Backend on port 4000')

# ------------------------------------------------------------
# ADJUSTER
# ------------------------------------------------------------
local_resource(
    'adjuster',
    serve_cmd='cd apps/adjuster && pnpm start',
    labels=['apps'],
    resource_deps=['db-migrations', 'adjuster-genTypes-init'],
    links=['http://localhost:4001'],
)

print('✅ Adjuster on port 4001')

# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
local_resource(
    'frontend',
    serve_cmd='cd apps/frontend && pnpm start',
    labels=['apps'],
    resource_deps=['db-migrations'],
    links=['http://localhost:4002'],
)

print('✅ Frontend on port 4002')

# ------------------------------------------------------------
# ON-DEMAND: Generate Types
# ------------------------------------------------------------
local_resource(
    'adjuster-genTypes',
    cmd='cd apps/adjuster && pnpm genTypes',
    labels=['generate-types'],
    auto_init=False,
)

local_resource(
    'backend-genTypes',
    cmd='cd apps/backend && pnpm genTypes',
    labels=['generate-types'],
    auto_init=False,
)

print('🔧 genTypes commands available on-demand')

# ------------------------------------------------------------
# ON-DEMAND: Clear Parcel Cache Adjuster
# ------------------------------------------------------------
local_resource(
    'clear-adjuster-cache',
    cmd='''
        echo "🧹 Clearing Parcel cache for adjuster..."        
        rm -rf apps/adjuster/.parcel-cache
        echo "✅ Parcel cache cleared for adjuster"
    ''',
    labels=['setup'],
    auto_init=False,
)
# ------------------------------------------------------------
# ON-DEMAND: Clear Parcel Cache Frontend
# ------------------------------------------------------------
local_resource(
    'clear-frontend-cache',
    cmd='''
        echo "🧹 Clearing Parcel cache for frontend..."
        rm -rf apps/frontend/.parcel-cache
        echo "✅ Parcel cache cleared for frontend"
    ''',
    labels=['setup'],
    auto_init=False,
)

print('🧹 clear-parcel-cache available on-demand')

print('')
print('🎉 Local dev ready!')
print('📖 Run: tilt up -f Tiltfile.local')
