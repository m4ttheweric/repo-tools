#!/usr/bin/env sh

# Run prettier on staged files before committing
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json|css|scss|md|yaml|yml|graphql)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "Running prettier on staged files..."
  echo "$STAGED_FILES" | xargs /usr/local/bin/pnpm exec prettier --write
  echo "$STAGED_FILES" | xargs git add
fi
