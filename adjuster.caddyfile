{
	auto_https off
}

http://127.0.0.1:4001 {

	@a host adjuster-one.localtest.me
	handle @a {
		header X-Proxy-Target "52001"
		reverse_proxy 127.0.0.1:52001
	}

	@b host adjuster-two.localtest.me
	handle @b {
		header X-Proxy-Target "52002"
		reverse_proxy 127.0.0.1:52002
	}

	handle {
		respond "no match" 404
	}
}